###############################################################################
# Vivado/Verilog whitelist .gitignore
# Default: ignore everything, then allow only what we want to keep.
###############################################################################

# 1) Ignore everything
*
# 2) But do not ignore folders (needed so whitelisted files in subfolders work)
!*/

###############################################################################
# HDL sources (keep)
###############################################################################
!*.v
!*.sv
!*.vh
!*.svh
!*.vhd
!*.vhdl

###############################################################################
# Constraints (keep)
###############################################################################
!*.xdc
!*.ucf

###############################################################################
# Tcl / scripts (keep)
###############################################################################
!*.tcl
!*.sh
!*.bat
!*.cmd
!*.py
!*.pl
!Makefile
!CMakeLists.txt

###############################################################################
# Block Design / IP configuration (keep)
###############################################################################
# Block design files
!*.bd
!*.bxml

# IP core configuration
!*.xci
!*.xcix
!*.xco
!*.coe
!*.prj

# (optional) IP packaged / catalog metadata (keep if you use packaged IP)
!*.xml

###############################################################################
# Simulation sources & config (keep)
###############################################################################
!*.do
!*.tcl
!*.f
!*.cfg
!*.ini

###############################################################################
# Docs / config / misc (keep)
###############################################################################
!*.md
!*.txt
!*.rst
!*.pdf
# !*.png
!*.jpg
!*.jpeg
!*.svg
!*.json
!*.yml
!*.yaml
!*.toml
# !*.csv
###############################################################################
# Git itself (keep)
###############################################################################
!.gitignore
!.gitattributes
!.gitmodules
!README
!README.*

###############################################################################
# Optional: keep only specific Vivado project files (uncomment if you want them)
###############################################################################
# !*.xpr
# !*.xpfm

/.history/
vivado/project_*/*

